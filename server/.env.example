## Backend environment variables (Express API)
## Copy this file to: server/.env
## Never commit real secrets.

# Server
PORT=8000
NODE_ENV=development

# Database
MONGO_URI=mongodb://127.0.0.1:27017/lms

# Auth
JWT_SECRET=REPLACE_ME_WITH_A_LONG_RANDOM_SECRET

# CORS / URLs (used by Socket.IO + Stripe redirect URLs)
FRONTEND_URL=http://localhost:3000

# Stripe (optional: required only for paid course enrollment)
STRIPE_SECRET_KEY=REPLACE_ME
STRIPE_WEBHOOK_SECRET=REPLACE_ME

# AI Provider (optional)
# OpenAI
OPENAI_API_KEY=REPLACE_ME
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small

# Anthropic (optional alternative)
ANTHROPIC_API_KEY=REPLACE_ME
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# RAG (optional)
# If set, backend will use MongoDB Atlas Vector Search via $vectorSearch on StudyChunk.embedding
MONGO_VECTOR_SEARCH_INDEX=study_chunks_vector
RAG_CHUNK_MIN_WORDS=220
RAG_CHUNK_MAX_WORDS=420
RAG_SUMMARY_MAX_CHUNKS=16

# Web search (Option A: Search API + LLM summary)
# Uses SerpAPI for Google results; then OpenAI summarizes strictly from snippets and returns bullet points + sources.
SERPAPI_API_KEY=REPLACE_ME
WEB_SEARCH_TOPK=5

